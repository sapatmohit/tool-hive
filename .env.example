# ============================================================
#  Tool Hive — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ============================================================

# ------------------------------------------------------------------
# MongoDB Connection
# Get your connection string from MongoDB Atlas:
#   https://cloud.mongodb.com → Connect → Drivers → Node.js
# ------------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/tool-hive?retryWrites=true&w=majority

# ------------------------------------------------------------------
# App URL (used for server-side absolute fetches during SSR/SSG)
# In development this is typically http://localhost:3000
# ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
